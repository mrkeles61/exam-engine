# Copy this file to .env and adjust values before running docker compose.
# Never commit .env to version control.

# -----------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------
POSTGRES_USER=examengine
POSTGRES_PASSWORD=changeme
POSTGRES_DB=examengine

# Full async connection URL consumed by FastAPI and Alembic.
# When running in Docker, hostname is the service name "postgres".
# When running locally, change to localhost.
DATABASE_URL=postgresql+asyncpg://examengine:changeme@postgres:5432/examengine

# -----------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------
# JWT — generate a strong key with: openssl rand -hex 32
# -----------------------------------------------------------------------
JWT_SECRET_KEY=your-secret-key-change-this

# -----------------------------------------------------------------------
# Demo seed credentials
# -----------------------------------------------------------------------
ADMIN_EMAIL=admin@university.edu
ADMIN_PASSWORD=admin123
